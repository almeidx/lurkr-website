{
	"name": "@lurkr/docs",
	"private": true,
	"homepage": "https://lurkr.gg/docs",
	"type": "module",
	"scripts": {
		"build": "next build",
		"build:typecheck": "tsc --noEmit",
		"build:cf": "opennextjs-cloudflare build",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
		"deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"dev": "next dev",
		"fmt": "biome check --write --unsafe",
		"fmt:content": "oxfmt --write content",
		"format": "pnpm run fmt",
		"postinstall": "next typegen && fumadocs-mdx && node scripts/generate-api-endpoint-docs.ts",
		"lint": "biome check",
		"preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"start": "next start"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.11",
		"@radix-ui/react-popover": "^1.1.16",
		"class-variance-authority": "^0.7.1",
		"fumadocs-core": "^16.9.3",
		"fumadocs-mdx": "^15.0.11",
		"fumadocs-openapi": "^10.10.3",
		"fumadocs-ui": "^16.9.3",
		"lucide-react": "^1.17.0",
		"next": "^16.2.7",
		"next-nprogress-bar": "^2.4.7",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"shiki": "^4.2.0",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/mdx": "^2.0.14",
		"@types/node": "^24.13.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"gray-matter": "^4.0.3",
		"oxfmt": "^0.54.0",
		"postcss": "^8.5.15",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-mdx": "^3.1.1",
		"remark-stringify": "^11.0.0",
		"slugify": "^1.6.9",
		"tailwind-scrollbar": "^4.0.2",
		"tailwindcss": "^4.3.0",
		"typescript": "~6.0.3",
		"wrangler": "^4.98.0"
	},
	"engines": {
		"node": ">=24.16.0"
	}
}
