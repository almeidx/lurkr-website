{
	"name": "@lurkr/docs",
	"private": true,
	"homepage": "https://lurkr.gg/docs",
	"type": "module",
	"scripts": {
		"build": "next build",
		"build:typecheck": "tsc --noEmit",
		"build:cf": "opennextjs-cloudflare build",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
		"deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"dev": "next dev",
		"fmt": "biome check --write --unsafe",
		"fmt:content": "pnpm dlx prettier --print-width=120 --use-tabs=true --prose-wrap=always --write \"content/**/*.mdx\"",
		"format": "pnpm run fmt",
		"postinstall": "next typegen && fumadocs-mdx && node scripts/generate-api-endpoint-docs.ts",
		"lint": "biome check",
		"preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"start": "next start"
	},
	"dependencies": {
		"@radix-ui/react-popover": "^1.1.15",
		"@opennextjs/cloudflare": "^1.17.1",
		"class-variance-authority": "^0.7.1",
		"fumadocs-core": "^16.6.12",
		"fumadocs-mdx": "^14.2.9",
		"fumadocs-openapi": "^10.3.17",
		"fumadocs-ui": "^16.6.12",
		"lucide-react": "^0.577.0",
		"next": "^16.1.6",
		"next-nprogress-bar": "^2.4.7",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"shiki": "^4.0.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/mdx": "^2.0.13",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"gray-matter": "^4.0.3",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-mdx": "^3.1.1",
		"remark-stringify": "^11.0.0",
		"slugify": "^1.6.6",
		"tailwind-scrollbar": "^4.0.2",
		"tailwindcss": "^4.2.1",
		"typescript": "~5.9.3",
		"wrangler": "^4.71.0"
	},
	"engines": {
		"node": ">=24.14.0"
	}
}
