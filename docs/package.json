{
	"name": "@lurkr/docs",
	"private": true,
	"homepage": "https://lurkr.gg/docs",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"build": "pnpm run generate:routes && pnpm run generate:api-docs && vite build && node scripts/prepare-cloudflare-assets.ts",
		"build:typecheck": "pnpm run generate:routes && pnpm run generate:api-docs && fumadocs-mdx && tsc --noEmit",
		"cf:check": "pnpm run build && wrangler deploy --dry-run",
		"cf:typegen": "wrangler types",
		"dev": "pnpm run generate:routes && vite dev",
		"deploy": "pnpm run build && wrangler deploy",
		"fmt": "biome check --write --unsafe",
		"fmt:content": "pnpm dlx prettier --print-width=120 --use-tabs=true --prose-wrap=always --write \"content/**/*.mdx\"",
		"format": "pnpm run fmt",
		"generate:api-docs": "node scripts/generate-api-endpoint-docs.ts",
		"generate:routes": "tsr generate",
		"postinstall": "pnpm run generate:routes && fumadocs-mdx && node scripts/generate-api-endpoint-docs.ts",
		"lint": "biome check",
		"preview": "vite preview",
		"start": "vite preview"
	},
	"dependencies": {
		"@radix-ui/react-popover": "^1.1.15",
		"@tanstack/react-router": "^1.168.10",
		"@tanstack/react-start": "^1.167.16",
		"class-variance-authority": "^0.7.1",
		"fumadocs-core": "^16.7.7",
		"fumadocs-mdx": "^14.2.11",
		"fumadocs-openapi": "^10.6.1",
		"fumadocs-ui": "^16.7.7",
		"lucide-react": "^1.7.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"shiki": "^4.0.2",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@cloudflare/vite-plugin": "^1.30.3",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/router-cli": "^1.166.25",
		"@types/mdx": "^2.0.13",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"gray-matter": "^4.0.3",
		"prettier": "^3.8.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-mdx": "^3.1.1",
		"remark-stringify": "^11.0.0",
		"slugify": "^1.6.8",
		"tailwind-scrollbar": "^4.0.2",
		"tailwindcss": "^4.2.2",
		"typescript": "~6.0.2",
		"vite": "^8.0.3",
		"wrangler": "^4.79.0"
	},
	"engines": {
		"node": ">=24.14.1"
	}
}
