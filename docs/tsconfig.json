{
	"compilerOptions": {
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"jsx": "react-jsx",
		"paths": {
			"@/*": ["./src/*"],
			"collections/*": ["./.source/*"]
		},
		"target": "ES2022",
		"types": ["node", "react"]
	},
	"extends": "../tsconfig.json",
	"include": ["./source.config.ts", "./vite.config.ts", "./src/**/*.ts", "./src/**/*.tsx", "./.source/**/*.ts"]
}
