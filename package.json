{
	"name": "lurkr-website",
	"private": true,
	"homepage": "https://lurkr.gg",
	"type": "module",
	"scripts": {
		"build": "pnpm --recursive run build",
		"build:typecheck": "pnpm --recursive run build:typecheck",
		"fmt": "biome check --write --unsafe",
		"lint": "biome check",
		"prepare": "husky .github/husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/node": "^24.13.2",
		"husky": "^9.1.7",
		"nano-staged": "^1.0.2",
		"typescript": "~6.0.3"
	},
	"packageManager": "pnpm@11.6.0",
	"engines": {
		"node": ">=24.16.0"
	},
	"nano-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,json,jsonc,css}": "biome check --write --no-errors-on-unmatched"
	}
}
